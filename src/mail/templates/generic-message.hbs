<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        .body-bg { font-family: sans-serif; background-color: #f4f4f4; padding: 20px; margin: 0; }
        .container { background-color: #ffffff; max-width: 600px; margin: 0 auto; border-radius: 10px; overflow: hidden; border: 1px solid #e2e8f0; }
        .content { padding: 40px; }
        h2 { color: #1e293b; margin-top: 0; }
        .text { color: #334155; line-height: 1.6; font-size: 16px; }
    </style>
</head>
<body class="body-bg">
    <div class="container">
        {{> header }}

        <div class="content">
            {{#if name}}
                <h2>Hola, {{name}}</h2>
            {{/if}}

            <div class="text">
                {{{message}}}
            </div>
        </div>

        {{> footer }}
    </div>
</body>
</html>